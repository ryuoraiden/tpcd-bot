# Copy to .env and fill in. Never commit .env (or put real values in this file).

# Bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your-bot-token-here

# Channel + role IDs (bare numeric IDs, right-click with Developer Mode on)
POLL_CHANNEL_ID=
POLL_PING_ROLE_ID=

# Welcome/goodbye messages (leave empty to disable; if set, also enable
# "Server Members Intent" for the bot in the Discord developer portal)
WELCOME_CHANNEL_ID=
GOODBYE_CHANNEL_ID=

# Your Discord user ID (owner override + low-pool DM warnings)
OWNER_ID=

# Comma-separated ROLE IDs allowed to use staff commands
# (Captain, 1st Commander, Manager)
ADMIN_ROLE_IDS=

# Daily post time, 24h HH:MM in TIMEZONE
POST_TIME=09:00
TIMEZONE=Asia/Kolkata

# Poll duration in hours (server rule: 24)
POLL_DURATION_HOURS=24

# Weekly recap: 1 = on (Sunday 20:00 in TIMEZONE), 0 = off
WEEKLY_RECAP=1

# SQLite location (default is fine)
DB_PATH=data/tpcd.db
